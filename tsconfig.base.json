{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@blud/anim-compiler": ["packages/anim-compiler/src/index.ts"],
      "@blud/anim-core": ["packages/anim-core/src/index.ts"],
      "@blud/anim-editor-core": ["packages/anim-editor-core/src/index.ts"],
      "@blud/anim-editor-react": ["packages/anim-editor-react/src/index.ts"],
      "@blud/anim-exporter": ["packages/anim-exporter/src/index.ts"],
      "@blud/anim-runtime": ["packages/anim-runtime/src/index.ts"],
      "@blud/anim-schema": ["packages/anim-schema/src/index.ts"],
      "@blud/anim-three": ["packages/anim-three/src/index.ts"],
      "@blud/anim-utils": ["packages/anim-utils/src/index.ts"],
      "@blud/dev-sync": ["packages/dev-sync/src/index.ts"],
      "@blud/dev-sync/node": ["packages/dev-sync/src/node.ts"],
      "@blud/shared": ["packages/shared/src/index.ts"],
      "@blud/skatepark": ["packages/skatepark/src/index.ts"],
      "@blud/editor-core": ["packages/editor-core/src/index.ts"],
      "@blud/geometry-kernel": ["packages/geometry-kernel/src/index.ts"],
      "@blud/gameplay-runtime": ["packages/gameplay-runtime/src/index.ts"],
      "@blud/render-pipeline": ["packages/render-pipeline/src/index.ts"],
      "@blud/runtime-audio": ["packages/runtime-audio/src/index.ts"],
      "@blud/runtime-scripting": ["packages/runtime-scripting/src/index.ts"],
      "@blud/runtime-build": ["packages/runtime-build/src/index.ts"],
      "@blud/runtime-format": ["packages/runtime-format/src/index.ts"],
      "@blud/runtime-physics-rapier": ["packages/runtime-physics-rapier/src/index.ts"],
      "@blud/runtime-streaming": ["packages/runtime-streaming/src/index.ts"],
      "@blud/scene-importer": ["packages/scene-importer/src/index.ts"],
      "@blud/three-runtime": ["packages/three-runtime/src/index.ts"],
      "@blud/foliage": ["packages/foliage/src/index.ts"],
      "@blud/terrain": ["packages/terrain/src/index.ts"],
      "@blud/tool-system": ["packages/tool-system/src/index.ts"],
      "@blud/workers": ["packages/workers/src/index.ts"]
    }
  }
}
