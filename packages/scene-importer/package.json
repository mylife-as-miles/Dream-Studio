{
  "name": "@blud/scene-importer",
  "version": "0.1.11",
  "description": "Best-effort HTML/JS scene importer for Blob authoring scenes.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config ../../scripts/tsup.package.config.mjs",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vibe-stack/blob.git",
    "directory": "packages/scene-importer"
  },
  "bugs": {
    "url": "https://github.com/vibe-stack/blob/issues"
  },
  "homepage": "https://github.com/vibe-stack/blob/tree/main/packages/scene-importer",
  "dependencies": {
    "@babel/generator": "^7.29.0",
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@blud/editor-core": "*",
    "@blud/shared": "*",
    "jszip": "^3.10.1",
    "parse5": "^7.3.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6"
  }
}
