{
  "name": "@blud/architecture",
  "version": "0.1.0",
  "description": "Architecture geometry builders and materials for Blob authoring scenes.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config ../../scripts/tsup.package.config.mjs",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vibe-stack/blob.git",
    "directory": "packages/architecture"
  },
  "bugs": {
    "url": "https://github.com/vibe-stack/blob/issues"
  },
  "homepage": "https://github.com/vibe-stack/blob/tree/main/packages/architecture",
  "dependencies": {
    "@blud/geometry-kernel": "*",
    "@blud/shared": "*"
  }
}
